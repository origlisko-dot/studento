# Telegram bot token for the ONE public bot (from BotFather). Server-side only.
BOT_TOKEN=123456:your-public-bot-token
# The bot's @username (without @), shown on the TV pairing screen.
BOT_USERNAME=YourCastBot
# Shared secret used in the webhook path and X-Telegram-Bot-Api-Secret-Token header.
WEBHOOK_SECRET=pick-a-long-random-string
# Public HTTPS base URL where this server is reachable (used to build /media URLs).
PUBLIC_URL=https://your-host.example.com
# Port to listen on.
PORT=8080
